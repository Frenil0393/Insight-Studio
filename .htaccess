# ==============================================================================
# THE INSIGHT STUDIO - PRODUCTION .HTACCESS
# ==============================================================================

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. FORCE HTTPS (Secure your site)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. REDIRECT .HTML TO CLEAN URL (e.g., /about.html -> /about)
    # If a user types the .html version, switch it to the clean version
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.html
    RewriteRule ^/?(.*)\.html$ /$1 [L,R=301]

    # 3. INTERNALLY SERVE .HTML FILES FOR CLEAN URLS
    # If a user asks for /about, serve about.html silently
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# 4. ENABLE BROWSER CACHING (Speeds up the PWA & 3D Site)
# This saves your images, CSS, and JS to the user's phone/computer so the site feels instant.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# 5. NEVER CACHE HTML & SERVICE WORKER
# This forces the browser to check for new design updates and new code every single time they visit.
<IfModule mod_headers.c>
    # Prevent caching for all HTML files
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>

    # Prevent caching for the Progressive Web App Service Worker
    <Files "sw.js">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </Files>
</IfModule>